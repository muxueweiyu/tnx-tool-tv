{
  "name": "tnx-tool-tv",
  "version": "1.0.0",
  "description": "Industrial Grade YSP Decoding Gateway and TV Caster",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tnx-tv": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "playwright": "^1.49.0",
    "ws": "^8.18.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.21.5",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
